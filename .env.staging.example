# Supabase staging - public frontend variables
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase staging - local/server-side migration tools
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local app URL for staging validation
APP_PUBLIC_URL=http://localhost:5173

# Copy this file to .env.staging.local and fill locally.
# Never commit .env.staging.local.
# Never use SUPABASE_SERVICE_ROLE_KEY in frontend/VITE_* variables.
