# ─── Variáveis para as Edge Functions (Supabase secrets) ────────────────────
# Adicionar via: supabase secrets set KEY=VALUE

# Provider ativo: "zapi" (default) ou "evolution" (trocar no cutover B6)
WHATSAPP_PROVIDER=zapi

# Credenciais da Evolution API (usadas quando WHATSAPP_PROVIDER=evolution)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=mude-esta-chave-para-algo-seguro-32chars
EVOLUTION_INSTANCE=marineflow

# Credenciais Z-API (mantidas como fallback até remoção final — Tarefa S8)
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=

# ─── Evolution API — variáveis de ambiente ──────────────────────────────────
# Copie este arquivo para .env e preencha os valores antes de subir o stack.
#   cp .env.example .env

# ─── Autenticação da Evolution API ──────────────────────────────────────────
# Chave global de acesso à API REST da Evolution (Bearer token).
# Use uma string aleatória longa (mínimo 32 chars).
# Exemplo de geração: openssl rand -hex 32
AUTHENTICATION_API_KEY=mude-esta-chave-para-algo-seguro-32chars

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Credenciais do banco interno criado pelo docker-compose.
# Altere POSTGRES_PASSWORD para um valor forte em produção.
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution_senha_forte
POSTGRES_DB=evolution_db

# ─── Configurações gerais da Evolution API ───────────────────────────────────
# Nível de log: ERROR | WARN | INFO | DEBUG | VERBOSE | DARK | WEBHOOKS
LOG_LEVEL=ERROR
LOG_COLOR=true

# Excluir instância automaticamente após desconexão? (false = mantém sessão)
DEL_INSTANCE=false

# Limite de QR Codes gerados por sessão antes de desconectar automaticamente
QRCODE_LIMIT=30

# Habilitar suporte a múltiplas sessões por instância
INSTANCE_EXPIRY_TIME=0

# ─── Webhook global (opcional) ───────────────────────────────────────────────
# Se definido, a Evolution enviará todos os eventos para esta URL,
# além dos webhooks individuais por instância.
# WEBHOOK_GLOBAL_URL=https://seu-endpoint.example.com/webhook
# WEBHOOK_GLOBAL_ENABLED=false

# ─── Armazenamento de mídia ──────────────────────────────────────────────────
# 'local' salva arquivos localmente (no volume 'evolution_instances')
# 's3' usa um bucket S3/compatível
PROVIDER_ENABLED=false
# PROVIDER_TYPE=local

# ─── Telemetria / Analytics (opcional) ──────────────────────────────────────
# Desabilitar envio de dados de uso para os mantenedores da Evolution
TELEMETRY=false
